#!/bin/bash
# Configure WordPress to work behind an FRP reverse proxy.
#
# Two problems to solve:
# 1. WP_HOME / WP_SITEURL constants are set from docker-compose env vars —
#    all generated links point at localhost. We inject a mu-plugin that
#    filters option_home and option_siteurl to return the proxy URL instead
#    (fires at priority 100, after the constant-based filter at priority 1).
# 2. FRP terminates TLS at the edge but forwards X-Forwarded-Proto: http.
#    Detect via X-Forwarded-Host presence and set HTTPS on.
#
# Usage: docker exec wordpress bash /var/www/html/wp-content/plugins/tillit-payment-gateway/dev/patch-proxy <proxy_url>
# Undo:  docker exec wordpress bash /var/www/html/wp-content/plugins/tillit-payment-gateway/dev/patch-proxy --reset

set -e

PROXY_URL="$1"
MU_PLUGIN="/var/www/html/wp-content/mu-plugins/proxy-override.php"

# ── Reset mode ───────────────────────────────────────────────────────────────
if [ "$PROXY_URL" = "--reset" ]; then
    rm -f "$MU_PLUGIN"
    echo "Proxy reset"
    exit 0
fi

if [ -z "$PROXY_URL" ]; then
    echo "Usage: patch-proxy <proxy_url>"
    echo "       patch-proxy --reset"
    exit 1
fi

# ── Write mu-plugin ──────────────────────────────────────────────────────────
cat > "$MU_PLUGIN" << 'PHPEOF'
<?php
// Auto-generated by dev/patch-proxy — trust reverse proxy + override site URLs.
// Remove by running: docker exec wordpress bash .../dev/patch-proxy --reset
defined( 'ABSPATH' ) || exit;

if ( ! empty( $_SERVER['HTTP_X_FORWARDED_HOST'] ) ) {
    $_SERVER['HTTPS']       = 'on';
    $_SERVER['SERVER_PORT'] = 443;
}

// Override WP_HOME / WP_SITEURL constants via option filters. Priority 100
// fires after the constant-based filter registered at priority 1 in wp-load.php.
add_filter( 'option_home',    function() { return 'PROXY_URL_PLACEHOLDER'; }, 100 );
add_filter( 'option_siteurl', function() { return 'PROXY_URL_PLACEHOLDER'; }, 100 );
PHPEOF

sed -i "s|PROXY_URL_PLACEHOLDER|${PROXY_URL}|g" "$MU_PLUGIN"

echo "Proxy configured: ${PROXY_URL}"
