#: class/WC_ABN.php:2572
#, php-format
#| msgid ""
#| "%s credit approves 90% of business buyers, pays you upfront and minimise "
#| "your risk. To offer %s in your checkout, you need to signup. It’s quick, "
#| "easy and gives you immediate access to the %s Merchant Portal."
msgid ""
"%s credit approves 90%% of business buyers, pays you upfront and minimise "
"your risk. To offer %s in your checkout, you need to signup. It’s quick, "
"easy and gives you immediate access to the %s Merchant Portal."
msgstr ""
"%s credit keurt 90%% van de zakelijke kopers goed, betaalt u vooraf en "
"minimaliseert uw risico. Om %s aan te bieden in uw checkout, moet u zich "
"registreren. Het is snel, eenvoudig en geeft u direct toegang tot de %s "
"Merchant Portal."

#: class/WC_ABN.php:841
#, php-format
msgid ""
"%s has acknowledged request to fulfill %d order. An invoice will be sent to "
"the buyer when the fulfilment is complete."
msgid_plural ""
"%s has acknowledged request to fulfill %d orders. Invoices will be sent to "
"the buyers when the fulfilments are complete."
msgstr[0] ""
"%s heeft het verzoek om %d bestelling uit te voeren bevestigd. Wanneer de "
"uitvoering is voltooid, wordt er een factuur naar de koper verzonden."
msgstr[1] ""
"%s heeft verzoeken bevestigd om %d bestellingen uit te voeren. Facturen "
"worden naar de kopers verzonden wanneer de uitvoeringen zijn voltooid."

#: class/WC_ABN.php:955
#, php-format
msgid ""
"%s has acknowledged the request to fulfil the order. An invoice will be sent "
"to the buyer when the fulfilment is complete."
msgstr ""
"%s heeft het verzoek om de bestelling uit te voeren bevestigd. Er wordt een "
"factuur naar de koper gestuurd wanneer de uitvoering is voltooid."

